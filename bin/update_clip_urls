#!/usr/bin/env ruby

# Update YouTube Clip URLs in the database.
# Clips need youtube.com/clip/CLIP_ID URLs (not regular watch URLs).
#
# Usage:
#   bundle exec ruby bin/update_clip_urls          # dry run
#   bundle exec ruby bin/update_clip_urls --apply  # apply changes

$: << File.expand_path('../src', File.dirname(__FILE__))

require 'util/config'
require 'util/db_manager'

DRY_RUN = !ARGV.include?('--apply')

if DRY_RUN
  puts "=== DRY RUN (pass --apply to make changes) ===\n\n"
else
  puts "=== APPLYING CHANGES ===\n\n"
end

# Mapping: source video ID -> { clip_url, clip_id, title }
CLIP_MAPPING = {
  'd6ph7n4k35Y' => {
    clip_url: 'https://www.youtube.com/clip/UgkxfSrkkeGc-RzeXJGv1e1ZX5A8IJLVImPJ',
    title: 'Pick and Pen - I changed my mind'
  },
  '3eZfUbfl-MA' => {
    clip_url: 'https://www.youtube.com/clip/UgkxcNvckNZorFP1VzHWwJk1rCDzd1ao3SBm',
    title: 'LAST NIGHT I WAS TWO CATS'
  },
  'FRUaXmqxjJk' => {
    clip_url: 'https://www.youtube.com/clip/UgkxNfgVYLaohSr54cwKIhOeKND0m_ZDfvvw',
    title: "MAO's BARBERSHOP"
  }
}

db = DaVaz::Util::DbManager.new
clips = db.load_clips
puts "Found #{clips.length} clips in database\n\n"

updated = 0
already_ok = 0
not_found = 0

clips.each do |clip|
  if clip.url =~ %r{youtube\.com/clip/}
    puts "#{clip.artobject_id}: #{clip.title} ... ALREADY CLIP URL"
    already_ok += 1
    next
  end

  # Extract video ID from current URL
  video_id = nil
  if clip.url =~ %r{(?:youtube\.com/watch\?.*v=|youtu\.be/)([A-Za-z0-9_-]{11})}
    video_id = $1
  end

  unless video_id
    puts "#{clip.artobject_id}: #{clip.title} ... NO VIDEO ID IN URL"
    not_found += 1
    next
  end

  if CLIP_MAPPING.key?(video_id)
    mapping = CLIP_MAPPING[video_id]
    puts "#{clip.artobject_id}: #{clip.title}"
    puts "       Old: #{clip.url}"
    puts "       New: #{mapping[:clip_url]}"
    unless DRY_RUN
      db.update_artobject(clip.artobject_id, { url: mapping[:clip_url] })
      puts "       UPDATED!"
    end
    updated += 1
  else
    puts "#{clip.artobject_id}: #{clip.title} (video_id: #{video_id}) ... NO CLIP MAPPING"
    not_found += 1
  end
end

puts "\n=== Summary ==="
puts "Total clips:   #{clips.length}"
puts "Would update:  #{updated}" if DRY_RUN
puts "Updated:       #{updated}" unless DRY_RUN
puts "Already OK:    #{already_ok}"
puts "Not found:     #{not_found}"
puts "\nRun with --apply to make changes." if DRY_RUN
