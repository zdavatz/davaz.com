#!/usr/bin/env ruby

# Script to replace YouTube URLs in the database with their
# "Enhanced 4K" versions. For each movie artobject with a YouTube URL:
# 1. Get the video title from the YouTube API
# 2. Search for a video with the same title + "(Enhanced 4K)"
# 3. If found, update the URL in the database
#
# Usage:
#   bundle exec ruby bin/update_youtube_4k          # dry run (no changes)
#   bundle exec ruby bin/update_youtube_4k --apply  # apply changes

$: << File.expand_path('../src', File.dirname(__FILE__))

require 'net/http'
require 'json'
require 'uri'
require 'util/config'
require 'util/db_manager'
require 'util/youtube_helper'

DRY_RUN = !ARGV.include?('--apply')

if DRY_RUN
  puts "=== DRY RUN (pass --apply to make changes) ===\n\n"
else
  puts "=== APPLYING CHANGES ===\n\n"
end

api_keys = DaVaz::Util::YoutubeHelper.api_keys
if api_keys.empty?
  puts "ERROR: No YouTube API keys found. Set up .yt-keys or YOUTUBE_API_KEY env var."
  exit 1
end

db = DaVaz.config.db_manager

# Load all movies
movies = db.load_movies
puts "Found #{movies.length} movies in database\n\n"

def youtube_api_get(path, api_key)
  uri = URI("https://www.googleapis.com/youtube/v3/#{path}&key=#{api_key}")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = true
  http.open_timeout = 10
  http.read_timeout = 10
  response = http.get(uri.request_uri)
  JSON.parse(response.body)
end

def get_video_title(video_id, api_keys)
  api_keys.each do |key|
    data = youtube_api_get("videos?part=snippet&id=#{video_id}", key)
    if data['items'] && !data['items'].empty?
      return data['items'][0]['snippet']['title']
    end
  end
  nil
end

def search_enhanced_4k(title, api_keys)
  search_query = URI.encode_www_form_component("#{title} (Enhanced 4K)")
  api_keys.each do |key|
    data = youtube_api_get("search?part=snippet&q=#{search_query}&type=video&maxResults=5", key)
    next unless data['items']
    data['items'].each do |item|
      item_title = item['snippet']['title']
      # Check if this is the Enhanced 4K version of the same video
      if item_title.include?('Enhanced 4K') || item_title.include?('enhanced 4k')
        # Verify title matches (without the 4K suffix)
        base_title = item_title
          .gsub(/\s*[\(\[]\s*Enhanced\s+4K\s*[\)\]]\s*/i, '')
          .gsub(/\s*-?\s*Enhanced\s+4K\s*/i, '')
          .strip
        if base_title.downcase == title.downcase || title.downcase.include?(base_title.downcase) || base_title.downcase.include?(title.downcase)
          return {
            video_id: item['id']['videoId'],
            title: item_title
          }
        end
      end
    end
  end
  nil
end

updated = 0
skipped = 0
not_found = 0
errors = 0

movies.each do |movie|
  video_id = DaVaz::Util::YoutubeHelper.extract_video_id(movie.url)
  unless video_id
    skipped += 1
    next
  end

  print "#{movie.artobject_id}: #{movie.title} ... "

  begin
    # Get current video title
    title = get_video_title(video_id, api_keys)
    unless title
      puts "SKIP (could not fetch title)"
      skipped += 1
      next
    end

    # Already an Enhanced 4K version?
    if title.include?('Enhanced 4K') || title.include?('enhanced 4k')
      puts "SKIP (already 4K: #{title})"
      skipped += 1
      next
    end

    print "\"#{title}\" -> "

    # Search for Enhanced 4K version
    result = search_enhanced_4k(title, api_keys)
    if result
      new_url = "https://www.youtube.com/watch?v=#{result[:video_id]}"
      puts "FOUND: #{result[:title]}"
      puts "       Old: #{movie.url}"
      puts "       New: #{new_url}"

      unless DRY_RUN
        db.update_artobject(movie.artobject_id, { url: new_url })
        puts "       UPDATED!"
      end
      updated += 1
    else
      puts "NOT FOUND"
      not_found += 1
    end
  rescue StandardError => e
    puts "ERROR: #{e.message}"
    errors += 1
  end
end

puts "\n=== Summary ==="
puts "Total movies:  #{movies.length}"
puts "Would update:  #{updated}" if DRY_RUN
puts "Updated:       #{updated}" unless DRY_RUN
puts "Not found:     #{not_found}"
puts "Skipped:       #{skipped}"
puts "Errors:        #{errors}"
puts "\nRun with --apply to make changes." if DRY_RUN
